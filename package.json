    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.17",
    "expo-speech": "~13.0.0",
    "expo-splash-screen": "~0.29.18",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
